{
  "name": "@riffcast/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "RiffCast CLI — `riffcast` command-line entry point.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "riffcast": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun run scripts/build.ts",
    "build:host": "bun run scripts/build.ts --target=bun-darwin-arm64"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@riffcast/core": "workspace:*",
    "@riffcast/mcp": "workspace:*",
    "@riffcast/skill": "workspace:*"
  }
}
