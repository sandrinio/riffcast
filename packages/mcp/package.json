{
  "name": "@riffcast/mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "RiffCast MCP server — exposes plan/render/review as MCP tools over stdio.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "riffcast-mcp": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "bun": "./src/server.ts",
      "default": "./src/server.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@riffcast/core": "workspace:*",
    "@riffcast/skill": "workspace:*",
    "zod": "^3.23.0"
  }
}
