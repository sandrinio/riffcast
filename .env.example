# Copy this file to .env and fill in real values. .env is git-ignored.
#
# Bun loads .env automatically via process.env at runtime. No dotenv import needed.

# npm Personal Access Token — required for `bun publish` of @riffcast/* packages.
# Generate at https://www.npmjs.com/settings/<your-username>/tokens
# Use a Granular Access Token scoped to the @riffcast org with Publish permission.
NPM_PAT=
